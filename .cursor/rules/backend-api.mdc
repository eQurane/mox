GET  /api/media/:mediaId/comments   → 200 | 400 | 401 | 403 | 404 | 500  (Bearer)
POST /api/media/:mediaId/comments   → 201 | 400 | 401 | 403 | 404 | 500  (Bearer)
GET  /api/notifications             → 200 | 401 | 403 | 500  (Bearer)
GET  /api/admin/users               → 200 | 401 | 403 | 500  (Bearer, только Админ)
GET  /api/admin/users/:id            → 200 | 400 | 401 | 403 | 404 | 500  (Bearer)
PATCH /api/admin/users/:id           → 200 | 400 | 401 | 403 | 404 | 500  (Bearer)
POST /api/admin/users/:id/approve   → 200 | 400 | 401 | 403 | 404 | 500  (Bearer)
DELETE /api/admin/users/:id         → 200 | 400 | 401 | 403 | 404 | 409 | 500  (Bearer)
GET  /api/admin/overview            → 200 | 401 | 403 | 500  (Bearer)
GET  /api/admin/issues               → 200 | 401 | 403 | 500  (Bearer)
GET  /api/admin/storage/large-files  → 200 | 401 | 403 | 500  (Bearer)
DELETE /api/admin/media/:id         → 200 | 400 | 401 | 403 | 404 | 500  (Bearer)
