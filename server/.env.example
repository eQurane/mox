# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=mox
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

PORT=3000

# JWT (в production обязателен сильный секрет)
# JWT_SECRET=
# JWT_EXPIRES_IN=7d

# Статус новой учётной записи при POST /api/auth/register — точное имя из таблицы statuses_users.
# Для модерации админом: На подтверждении
# Для локальной разработки без очереди: Активный
REGISTER_USER_STATUS=На подтверждении

# Нижняя граница дат при создании таблиц (db_init)
# INIT_DATE=2026-05-01
